# Local-only design/planning material (not committed)
design/

# Secrets
.env
.env.*
!.env.example

# Steering config — the example skeletons are tracked, the real team content is not.
# (Untracking does not erase history; see the storage design spec.)
translation/*
!translation/*.example.json
!translation/*.example.md
conversion/*
!conversion/*.example.json
!conversion/*.example.md

# Local keys (Google service account JSON, etc.) — never commit the actual keys
keys/*
!keys/.gitkeep
!keys/README.md

# Dependencies / build
node_modules/
dist/

# Collector output (local JSON)
output/

# Frontend build output / deps
web/dist/
web/node_modules/

# Playwright MCP session dumps (console logs + page snapshots, timestamped per run)
.playwright-mcp/
