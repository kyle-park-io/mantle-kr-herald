# Required for all twitterapi.io reads (module A — X data collection)
TWITTERAPI_IO_KEY=

# Required for Lark reads (subsystem B — Lark data collection).
# Create a custom app in the Lark Developer Console to get these,
# grant scope im:message.history:readonly (or im:message:readonly),
# and add the app/bot to each target group chat.
LARK_APP_ID=
LARK_APP_SECRET=
# Comma-separated chat_id(s) of the target group(s) to collect from
# (e.g. "Mantle News Announcement & MKT Task 2.0").
LARK_CHAT_IDS=
# Optional API base domain. Default: https://open.larksuite.com (Larksuite international).
# Use https://open.feishu.cn for Feishu (China).
LARK_BASE_URL=

# === Google Drive upload (subsystem D) — pick ONE auth method. See
# === docs/guides/google-drive-setup-guide.md. Auto-detected from the vars below;
# === force with GOOGLE_AUTH_MODE = oauth | service_account.
GOOGLE_AUTH_MODE=
#
# Method A — OAuth (recommended for a personal Gmail account). Files are owned by
# YOU (you have storage quota). Create an OAuth client (type: Desktop app), set the
# id/secret, then run `pnpm google:auth` to mint the refresh token.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
#
# Method B — Service account. NOTE: a service account has NO storage quota, so it can
# only upload into a Google Workspace **Shared Drive** (or via domain-wide delegation),
# NOT a personal Drive. Set GOOGLE_AUTH_MODE=service_account to use this.
GOOGLE_SA_KEY_FILE=keys/mantle-sa.json
#
# Folder IDs (printed by `pnpm drive:init`, or copied from the Drive folder URL).
GDRIVE_REVIEW_FOLDER_ID=
GDRIVE_APPROVED_FOLDER_ID=
# Comma-separated team emails to share the review/approved folders with (editor), used by `pnpm drive:init`.
GDRIVE_SHARE_EMAILS=
# Optional: name of the parent folder drive:init creates (default: "Mantle KR Herald");
# review/approved are nested inside it and the parent is shared with the team (children inherit).
GDRIVE_PARENT_FOLDER_NAME=

# Required for Lark Drive upload (subsystem D). Reuses the Lark app above
# (LARK_APP_ID/SECRET) — add a drive scope to it. Folder tokens are in the
# Lark drive folder URL.
LARK_DRIVE_REVIEW_FOLDER_TOKEN=
LARK_DRIVE_APPROVED_FOLDER_TOKEN=
