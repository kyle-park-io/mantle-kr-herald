# ─────────────────────────────────────────────────────────────────────────────
# mantle-kr-herald — environment
#
# Every line is tagged so you can see at a glance what you actually have to set:
#
#   [REQUIRED]  the command will not run without it
#   [OPTIONAL]  has a working default, or the feature is simply off without it
#   [PICK ONE]  one of a set — see the block's note
#
# Nothing here is needed for the translate / convert / format stages: those never
# call an external API. Setup procedures live in docs/ko/setup/ — this file only
# names the variables. Check your setup with `pnpm doctor`.
# ─────────────────────────────────────────────────────────────────────────────


# ═══ 1. Always ═══════════════════════════════════════════════════════════════

# [REQUIRED] Where approved artifacts are preserved.
#
# **Start with `local`, and switch to `cloud` once your setup is finished.**
# That is the intended path, not a fallback: in local mode the whole pipeline
# runs — collect, translate, convert, format, review — with no cloud credentials
# at all. Section 3 below stays empty until you are ready. When Drive/Sheet is
# provisioned and `pnpm doctor` is green, change this one line to `cloud`.
#
#   local — everything stays under output/, including the published documents
#           (output/publish/local/{review,approved}/). **You own that tree**: it
#           is git-ignored, so nothing backs it up for you. Know what lives where
#           (docs/ko/artifacts.md) and run `pnpm archive` / `pnpm clean` to keep
#           it from growing without bound.
#   cloud — Google/Lark Drive becomes the record of truth; drive:publish uploads
#           there, the Sheet commands run, and section 3 becomes required.
#           output/ is still your working tree — the Drive copy is the record,
#           not a backup of it.
#
# Never inferred. An unset value fails loudly rather than guessing, because
# guessing wrong sends published work to the wrong place: a cloud operator would
# find their documents sitting in output/ instead of Drive, with drive:publish
# reporting success either way.
#
# Promotion steps: docs/ko/quickstart.md §5.
HERALD_STORAGE_MODE=local


# ═══ 2. Collection sources ═══════════════════════════════════════════════════
# Needed in BOTH storage modes, but only for the sources you actually collect
# from. Collecting from X only? Leave the Lark block empty, and vice versa.

# [REQUIRED for `pnpm collect`] twitterapi.io API key (module A — X collection).
TWITTERAPI_IO_KEY=

# [REQUIRED for `pnpm collect-lark`, `pnpm lark:chats`, `pnpm lark:send`]
# Create a custom app in the Lark Developer Console, grant scope
# im:message.history:readonly (or im:message:readonly), and add the app/bot to
# each target group chat. See docs/ko/setup/lark.md.
LARK_APP_ID=
LARK_APP_SECRET=

# [REQUIRED for `pnpm collect-lark`] Comma-separated chat_id(s) to collect from
# (e.g. "Mantle News Announcement & MKT Task 2.0"). Find ids with
# `pnpm lark:chats`, which needs only the app credentials above — so leave this
# empty on first run. `pnpm lark:send` also works without it, but then --chat
# is mandatory rather than defaulting to the first id here.
LARK_CHAT_IDS=

# [OPTIONAL] API base domain. Default: https://open.larksuite.com (Larksuite
# international). Use https://open.feishu.cn for Feishu (China).
LARK_BASE_URL=


# ═══ 3. Cloud mode ═══════════════════════════════════════════════════════════
# Only read when HERALD_STORAGE_MODE=cloud. In local mode, four commands —
# drive:init, sheet:init, targets:list, history:record — skip with a message and
# exit 0, so you can leave the whole section empty. drive:publish is not one of
# them: in local mode it targets the filesystem instead of Drive, so it still
# runs, and it does not need anything from this section to do so.

# ── 3a. Google auth — [PICK ONE] method A or B ───────────────────────────────
# Detected automatically: a refresh token means OAuth, otherwise a key file
# means service account. Set this only to force one when both are present.
# Valid values: oauth | service_account
GOOGLE_AUTH_MODE=

# Method A — OAuth. Recommended, and the only option for a personal Gmail
# account: files are owned by YOU, so they use your storage quota.
# Create an OAuth client (type: Desktop app), set the id/secret, then run
# `pnpm google:auth` to mint the refresh token. See docs/ko/setup/google-drive.md.
# [REQUIRED for method A]
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# [OPTIONAL] Space-separated OAuth scopes requested by `pnpm google:auth`.
# Default: https://www.googleapis.com/auth/drive.file (least privilege).
# Widen it only when you need to — the Sheet hub (3c) needs the extra scope:
#   GOOGLE_OAUTH_SCOPE="https://www.googleapis.com/auth/drive.file https://www.googleapis.com/auth/spreadsheets"
# Changing this has no effect until you re-run `pnpm google:auth`; the token
# already carries the scopes it was minted with. `pnpm doctor --live` prints the
# scopes actually granted.
GOOGLE_OAUTH_SCOPE=

# Method B — Service account. A service account has NO storage quota of its own,
# so it can only upload into a Google Workspace **Shared Drive** (or via
# domain-wide delegation) — never a personal Drive. Leave empty for method A.
# [REQUIRED for method B] Path to the JSON key, e.g. keys/mantle-sa.json
GOOGLE_SA_KEY_FILE=

# ── 3b. Google Drive folders (subsystem D) ───────────────────────────────────
# [REQUIRED for `pnpm drive:publish`] Printed by `pnpm drive:init`, or copied
# from the Drive folder URL.
GDRIVE_REVIEW_FOLDER_ID=
GDRIVE_APPROVED_FOLDER_ID=

# [OPTIONAL] Used by `pnpm drive:init` only. Comma-separated team emails to
# share the folders with as editors. Empty means the folders stay private to you.
GDRIVE_SHARE_EMAILS=

# [OPTIONAL] Name of the parent folder `pnpm drive:init` creates.
# Default: "Mantle KR Herald". review/approved are nested inside it, and sharing
# the parent is what gives the team access (children inherit).
GDRIVE_PARENT_FOLDER_NAME=

# ── 3c. Google Sheet data hub (§9a) ──────────────────────────────────────────
# [REQUIRED for `pnpm sheet:init`, `pnpm targets:list`, `pnpm history:record`]
# Spreadsheet id, printed by `pnpm sheet:init`. Reuses the Google auth above,
# but the token must carry the spreadsheets scope — see GOOGLE_OAUTH_SCOPE.
GSHEET_ID=

# ── 3d. Lark Drive upload (subsystem D) ──────────────────────────────────────
# [REQUIRED for `pnpm drive:publish --target lark|both`] Reuses the Lark app
# from section 2 — add a drive scope to it. Folder tokens are the last path
# segment of the Lark drive folder URL. Google-only publishing (the default)
# does not need these.
LARK_DRIVE_REVIEW_FOLDER_TOKEN=
LARK_DRIVE_APPROVED_FOLDER_TOKEN=


# ═══ 4. Local tools ══════════════════════════════════════════════════════════

# [OPTIONAL] Port for the review dashboard (`pnpm serve`). Default: 5757.
# The server binds localhost only; it is not meant to be exposed.
PORT=
