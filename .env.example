# Required for all twitterapi.io reads (module A — X data collection)
TWITTERAPI_IO_KEY=

# Required for Lark reads (subsystem B — Lark data collection).
# Create a custom app in the Lark Developer Console to get these,
# grant scope im:message.history:readonly (or im:message:readonly),
# and add the app/bot to each target group chat.
LARK_APP_ID=
LARK_APP_SECRET=
# Comma-separated chat_id(s) of the target group(s) to collect from
# (e.g. "Mantle News Announcement & MKT Task 2.0").
LARK_CHAT_IDS=
# Optional API base domain. Default: https://open.larksuite.com (Larksuite international).
# Use https://open.feishu.cn for Feishu (China).
LARK_BASE_URL=
