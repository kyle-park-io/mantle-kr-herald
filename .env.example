# Required for all twitterapi.io reads (module A — X data collection)
TWITTERAPI_IO_KEY=

# Required for Lark reads (subsystem B — Lark data collection).
# Create a custom app in the Lark Developer Console to get these,
# grant scope im:message.history:readonly (or im:message:readonly),
# and add the app/bot to each target group chat.
LARK_APP_ID=
LARK_APP_SECRET=
# Comma-separated chat_id(s) of the target group(s) to collect from
# (e.g. "Mantle News Announcement & MKT Task 2.0").
LARK_CHAT_IDS=
# Optional API base domain. Default: https://open.larksuite.com (Larksuite international).
# Use https://open.feishu.cn for Feishu (China).
LARK_BASE_URL=

# Required for Google Drive upload (subsystem D). Create a GCP service account,
# download its JSON key, enable Drive API, and share the target folders with the
# service account email. Folder IDs are in the Drive folder URL.
GOOGLE_SA_KEY_FILE=
GDRIVE_REVIEW_FOLDER_ID=
GDRIVE_APPROVED_FOLDER_ID=
# Comma-separated team emails to share the review/approved folders with (editor).
# Used by `pnpm drive:init` (the service account creates + shares the folders).
GDRIVE_SHARE_EMAILS=

# Required for Lark Drive upload (subsystem D). Reuses the Lark app above
# (LARK_APP_ID/SECRET) — add a drive scope to it. Folder tokens are in the
# Lark drive folder URL.
LARK_DRIVE_REVIEW_FOLDER_TOKEN=
LARK_DRIVE_APPROVED_FOLDER_TOKEN=
