{
  "name": "mantle-kr-herald",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "collect": "tsx --env-file-if-exists=.env src/cli/collect.ts",
    "collect-lark": "tsx --env-file-if-exists=.env src/cli/collect-lark.ts",
    "reconcile": "tsx --env-file-if-exists=.env src/cli/reconcile.ts",
    "translate:prepare": "tsx src/cli/translate-prepare.ts",
    "translate:save": "tsx src/cli/translate-save.ts",
    "convert:prepare": "tsx src/cli/convert-prepare.ts",
    "convert:save": "tsx src/cli/convert-save.ts",
    "format": "tsx src/cli/format.ts",
    "format:save": "tsx src/cli/format-save.ts",
    "glossary": "tsx src/cli/glossary.ts",
    "drive:publish": "tsx --env-file-if-exists=.env src/cli/publish.ts",
    "drive:init": "tsx --env-file-if-exists=.env src/cli/drive-init.ts",
    "targets:list": "tsx --env-file-if-exists=.env src/cli/targets-list.ts",
    "history:record": "tsx --env-file-if-exists=.env src/cli/history-record.ts",
    "sheet:init": "tsx --env-file-if-exists=.env src/cli/sheet-init.ts",
    "doctor": "tsx --env-file-if-exists=.env src/cli/doctor.ts",
    "status": "tsx src/cli/status.ts",
    "serve": "tsx --env-file-if-exists=.env src/cli/serve.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build:web": "vite build --config web/vite.config.ts",
    "google:auth": "tsx --env-file-if-exists=.env src/cli/google-auth.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "probe": "vitest run -c vitest.probe.config.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc -p web/tsconfig.json"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8"
  }
}
